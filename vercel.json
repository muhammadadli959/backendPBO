{
  "version": 2,
  "buildCommand": "cd backendPBO && npm install && npm run build",
  "outputDirectory": "backendPBO/backend/dist",
  "functions": {
    "backendPBO/backend/dist/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backendPBO/backend/dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
